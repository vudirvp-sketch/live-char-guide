# Live Character Guide v6 .gitignore
# Updated: 2026-04-20 for v6 rebuild

# ============================================================================
# BUILD ARTIFACTS
# ============================================================================

# Build hashes
/build-*.hash

# Root build hash (regenerated by build)
/build.hash


# Distribution output (generated by build-shell.mjs)
/dist/

# Build intermediate output (generated by build-layers.mjs from src/master/)
# After layer-config.json moved to root, build/ is fully regenerable
/build/

# Root deployment files (generated by build-shell.mjs, committed for GitHub Pages)
# These are deployment artifacts needed for GitHub Pages (no CI/CD pipeline).
# Regenerated by `pnpm run build` — commit after each build.
# DO NOT gitignore: index.html, assets/, widgets/, parts-l{1,2,3}/,
#   event-bus.js, data/, build.hash


# ============================================================================
# WIDGET & RUNTIME
# ============================================================================

# Widget cache
.widget-cache/

# CSP reports
csp-reports/

# ============================================================================
# DEPENDENCIES
# ============================================================================

node_modules/
.pnpm-store/

# ============================================================================
# ENVIRONMENT
# ============================================================================

.env
.env.*
.env.local
.env.*.local

# ============================================================================
# IDE & EDITORS
# ============================================================================

.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================================
# OS FILES
# ============================================================================

.DS_Store
Thumbs.db

# ============================================================================
# LOGS
# ============================================================================

*.log
npm-debug.log*
pnpm-debug.log

# ============================================================================
# TEST COVERAGE
# ============================================================================

coverage/

# ============================================================================
# TEMPORARY FILES
# ============================================================================

tmp/
temp/
*.tmp

# ============================================================================
# USER-GENERATED CONTENT
# ============================================================================

# Download directory (user-generated, keep local)
download/

# ============================================================================
# V6 SPECIFIC — DO NOT IGNORE
# ============================================================================

# IMPORTANT: These must be committed
# !build/layer-config.json
# !src/master/
# !docs/

# Layer config should be committed (source of truth for layer names)
!layer-config.json

