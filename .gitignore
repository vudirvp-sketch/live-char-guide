# Live Character Guide v6 .gitignore
# Updated: 2026-04-20 for v6 rebuild

# ============================================================================
# BUILD ARTIFACTS
# ============================================================================

# Build hashes
/build-*.hash


# Distribution output (generated by build-shell.mjs)
/dist/

# Root fallback files (generated by build, not committed)


# ============================================================================
# WIDGET & RUNTIME
# ============================================================================

# Widget cache
.widget-cache/

# CSP reports
csp-reports/

# ============================================================================
# DEPENDENCIES
# ============================================================================

node_modules/
.pnpm-store/

# ============================================================================
# ENVIRONMENT
# ============================================================================

.env
.env.*
.env.local
.env.*.local

# ============================================================================
# IDE & EDITORS
# ============================================================================

.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================================
# OS FILES
# ============================================================================

.DS_Store
Thumbs.db

# ============================================================================
# LOGS
# ============================================================================

*.log
npm-debug.log*
pnpm-debug.log

# ============================================================================
# TEST COVERAGE
# ============================================================================

coverage/

# ============================================================================
# TEMPORARY FILES
# ============================================================================

tmp/
temp/
*.tmp

# ============================================================================
# USER-GENERATED CONTENT
# ============================================================================

# Download directory (user-generated, keep local)
download/

# ============================================================================
# V6 SPECIFIC — DO NOT IGNORE
# ============================================================================

# IMPORTANT: These must be committed
# !build/layer-config.json
# !src/master/
# !docs/

# Layer config should be committed (source of truth for layer names)
!layer-config.json
