{
  "name": "live-char-guide",
  "version": "5.10.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Live Character Guide for LLM — Engineering pipeline for RP character cards",
  "scripts": {
    "build": "node src/scripts/build.mjs",
    "build:zero": "node src/scripts/build-zero-install.mjs",
    "build:all": "pnpm run build && pnpm run build:zero",
    "build:check": "pnpm run build:all && pnpm run validate",
    "build:watch": "chokidar 'src/**/*' -c 'pnpm run build:all'",
    "validate": "node scripts/validate-artifact.mjs",
    "version:check": "node scripts/version-sync.mjs",
    "test": "node --test tests/test-*.mjs tests/integration/*.mjs",
    "test:unit": "node --test tests/test-*.mjs",
    "test:integration": "node --test tests/integration/*.mjs",
    "test:a11y": "axe http://localhost:3000 --tags=wcag2a,wcag2aa --exit",
    "serve": "serve . -l 3000",
    "dev": "pnpm run build:all && pnpm run serve",
    "precommit": "pnpm run build:all && pnpm run validate",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "prettier --write .",
    "clean": "rm -rf node_modules package-lock.json pnpm-lock.yaml",
    "reinstall": "pnpm run clean && pnpm install"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.8.0",
    "@eslint/js": "^10.0.1",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.2.0",
    "puppeteer": "^21.0.0",
    "serve": "^14.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vudirvp-sketch/live-char-guide.git"
  },
  "keywords": [
    "llm",
    "rp",
    "character-card",
    "ai",
    "persona"
  ],
  "author": "TITAN FUSE Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vudirvp-sketch/live-char-guide/issues"
  },
  "homepage": "https://github.com/vudirvp-sketch/live-char-guide#readme"
}
